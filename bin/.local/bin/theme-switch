#!/usr/bin/env bash

ACTIVE_CONFIG="$HOME/.config/alacritty/active_theme.toml"
DARK_THEME="$HOME/.config/alacritty/themes/dark.toml"
LIGHT_THEME="$HOME/.config/alacritty/themes/light.toml"
NVIM_COLORS="$HOME/.config/nvim/after/plugin/colors.lua"

if [[ "$OSTYPE" == "darwin"* ]]; then
    IS_DARK=$(defaults read -g AppleInterfaceStyle 2>/dev/null)
else
    CURRENT_MODE=$(dconf read /org/gnome/desktop/interface/color-scheme)
    [[ "$CURRENT_MODE" == "'prefer-dark'" ]] && IS_DARK="Dark" || IS_DARK=""
fi

if [ "$IS_DARK" = "Dark" ]; then
    NEW_BG="light"
    nvr --serverlist | xargs -I {} nvr --servername {} -c  "lua vim.opt.background='$NEW_BG'; Colors()" 2>/dev/null

    if [[ "$OSTYPE" == "darwin"* ]]; then
        osascript -e 'tell app "System Events" to tell appearance preferences to set dark mode to false'
    else
        dconf write /org/gnome/desktop/interface/color-scheme "'prefer-light'"
        dconf write /org/gnome/desktop/interface/gtk-theme "'Adwaita'"
        hyprctl keyword general:col.active_border "rgba(33ccffee)" 2>/dev/null
    fi

    printf "[general]\nimport = [ \"$LIGHT_THEME\" ]\n" > "$ACTIVE_CONFIG"
    if [[ "$OSTYPE" == "darwin"* ]]; then
        sed -i '' "1s/.*/vim.opt.background = \"$NEW_BG\"/" "$NVIM_COLORS"
    else
        sed -i "1s/.*/vim.opt.background = \"$NEW_BG\"/" "$NVIM_COLORS"
    fi

    MSG="Light Mode"
else
    NEW_BG="dark"
    nvr --serverlist | xargs -I {} nvr --servername {} -c  "lua vim.opt.background='$NEW_BG'; Colors()" 2>/dev/null

    if [[ "$OSTYPE" == "darwin"* ]]; then
        osascript -e 'tell app "System Events" to tell appearance preferences to set dark mode to true'
    else
        dconf write /org/gnome/desktop/interface/color-scheme "'prefer-dark'"
        dconf write /org/gnome/desktop/interface/gtk-theme "'Nordic'"
        hyprctl keyword general:col.active_border "rgba(ff0000ee)" 2>/dev/null
    fi

    printf "[general]\nimport = [ \"$DARK_THEME\" ]\n" > "$ACTIVE_CONFIG"

    if [[ "$OSTYPE" == "darwin"* ]]; then
        sed -i '' "1s/.*/vim.opt.background = \"$NEW_BG\"/" "$NVIM_COLORS"
    else
        sed -i "1s/.*/vim.opt.background = \"$NEW_BG\"/" "$NVIM_COLORS"
    fi

    MSG="Dark Mode"
fi


if [[ "$OSTYPE" == "darwin"* ]]; then
    osascript -e "display notification \"Switched to $MSG\" with title \"Theme Swapper\""
else
    notify-send "$MSG"
fi
